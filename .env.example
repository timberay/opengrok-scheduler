# Batch Job Scheduler Configuration Template
# Copy this file to .env and adjust as needed

# Database & Logs
DB_PATH=data/scheduler.db
LOG_DIR=logs
# Log data retention in days
LOG_RETENTION_DAYS=30

# Scheduler Timing
# Format: HH:MM
START_TIME=18:00
END_TIME=06:00

# Monitoring & Thresholds
# Resource limit in percentage (0-100)
RESOURCE_THRESHOLD=70
# Interval to check for next job in seconds
CHECK_INTERVAL=300
# Idle timeout for a job with no CPU activity in seconds
JOB_IDLE_TIMEOUT=3600
# I/O Wait limit in percentage (defaults to 20)
IOWAIT_THRESHOLD=20
# Swap usage limit in percentage (defaults to 50)
SWAP_THRESHOLD=50
# Inode usage limit in percentage (defaults to 90)
INODE_THRESHOLD=90

# Concurrency Cap
# Maximum concurrent RUNNING jobs. Hard ceiling to prevent thundering-herd
# when multiple jobs transition from git-fetch (low load) to indexing (high load)
# at the same time. Measure server capacity for simultaneous indexing before tuning.
# Minimum value: 1. Setting 0 or negative disables all new jobs.
MAX_CONCURRENT_JOBS=3

# Device Specific (Optional, auto-detected if empty)
# DISK_DEVICE=sda
# NET_INTERFACE=eth0
# MAX_BANDWIDTH=12500000 # 100Mbps in bytes/s
